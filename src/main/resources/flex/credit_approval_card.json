{
  "type": "bubble",
  "size": "mega",
  "header": {
    "type": "box",
    "layout": "vertical",
    "contents": [
      {
        "type": "text",
        "text": "🟡 คิวใหม่: รอเช็คเครดิต",
        "weight": "bold",
        "color": "#FFFFFF",
        "size": "md"
      }
    ],
    "backgroundColor": "#FF9900",
    "paddingAll": "12px"
  },
  "body": {
    "type": "box",
    "layout": "vertical",
    "contents": [
      {
        "type": "text",
        "text": "บริการ: {{SERVICE_NAME}}",
        "weight": "bold",
        "size": "xl",
        "margin": "md"
      },
      {
        "type": "box",
        "layout": "vertical",
        "margin": "lg",
        "spacing": "sm",
        "contents": [
          {
            "type": "box",
            "layout": "baseline",
            "spacing": "sm",
            "contents": [
              {
                "type": "text",
                "text": "ลูกค้า",
                "color": "#aaaaaa",
                "size": "sm",
                "flex": 1
              },
              {
                "type": "text",
                "text": "{{USER_ID}}",
                "wrap": true,
                "color": "#666666",
                "size": "sm",
                "flex": 3,
                "weight": "bold"
              }
            ]
          },
          {
            "type": "box",
            "layout": "baseline",
            "spacing": "sm",
            "contents": [
              {
                "type": "text",
                "text": "ข้อมูล",
                "color": "#aaaaaa",
                "size": "sm",
                "flex": 1
              },
              {
                "type": "text",
                "text": "{{EXTRA_INFO}}",
                "wrap": true,
                "color": "#666666",
                "size": "sm",
                "flex": 3,
                "weight": "bold"
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "type": "box",
    "layout": "horizontal",
    "spacing": "sm",
    "contents": [
      {
        "type": "button",
        "style": "primary",
        "height": "sm",
        "action": {
          "type": "postback",
          "label": "✅ เครดิตผ่าน",
          "data": "action=approve_credit&service={{SERVICE_EN}}&userId={{USER_ID}}",
          "displayText": "แอดมินกด: เครดิตผ่าน (ลูกค้า: {{CUSTOMER_NAME}})"
        },
        "color": "#00B900"
      },
      {
        "type": "button",
        "style": "secondary",
        "height": "sm",
        "action": {
          "type": "postback",
          "label": "❌ ติดแบล็คลิสต์",
          "data": "action=reject_credit&service={{SERVICE_EN}}&userId={{USER_ID}}",
          "displayText": "แอดมินกด: ติดแบล็คลิสต์ (ลูกค้า: {{CUSTOMER_NAME}})"
        },
        "color": "#F0F0F0"
      }
    ]
  }
}