{
  "type": "bubble",
  "size": "mega",
  "header": {
    "type": "box",
    "layout": "vertical",
    "contents": [
      {
        "type": "text",
        "text": "🔵 คิวใหม่: รอตรวจเอกสาร",
        "weight": "bold",
        "color": "#FFFFFF",
        "size": "md"
      }
    ],
    "backgroundColor": "#007BFF",
    "paddingAll": "12px"
  },
  "body": {
    "type": "box",
    "layout": "vertical",
    "contents": [
      {
        "type": "text",
        "text": "บริการ: {{SERVICE_NAME}}",
        "weight": "bold",
        "size": "xl",
        "margin": "md"
      },
      {
        "type": "box",
        "layout": "vertical",
        "margin": "lg",
        "spacing": "sm",
        "contents": [
          {
            "type": "box",
            "layout": "baseline",
            "spacing": "sm",
            "contents": [
              {
                "type": "text",
                "text": "ลูกค้า",
                "color": "#aaaaaa",
                "size": "sm",
                "flex": 1
              },
              {
                "type": "text",
                "text": "{{USER_ID}}",
                "wrap": true,
                "color": "#666666",
                "size": "sm",
                "flex": 3,
                "weight": "bold"
              }
            ]
          },
          {
            "type": "box",
            "layout": "baseline",
            "spacing": "sm",
            "contents": [
              {
                "type": "text",
                "text": "สถานะ",
                "color": "#aaaaaa",
                "size": "sm",
                "flex": 1
              },
              {
                "type": "text",
                "text": "{{EXTRA_INFO}}",
                "wrap": true,
                "color": "#666666",
                "size": "sm",
                "flex": 3,
                "weight": "bold"
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "type": "box",
    "layout": "horizontal",
    "spacing": "sm",
    "contents": [
      {
        "type": "button",
        "style": "primary",
        "height": "sm",
        "action": {
          "type": "postback",
          "label": "✅ เอกสารครบ",
          "data": "action=approve_doc&service={{SERVICE_EN}}&userId={{USER_ID}}",
          "displayText": "แอดมินกด: เอกสารครบถ้วน"
        },
        "color": "#00B900"
      },
      {
        "type": "button",
        "style": "secondary",
        "height": "sm",
        "action": {
          "type": "postback",
          "label": "❌ ขอเพิ่ม",
          "data": "action=request_more_doc&service={{SERVICE_EN}}&userId={{USER_ID}}",
          "displayText": "แอดมินกด: ขอเอกสารเพิ่ม"
        },
        "color": "#F0F0F0"
      }
    ]
  }
}